####### Build rules

SIPConnectivityTester.app/Contents/MacOS/SIPConnectivityTester:  $(OBJECTS)  
	@test -d SIPConnectivityTester.app/Contents/MacOS/ || mkdir -p SIPConnectivityTester.app/Contents/MacOS/
	$(LINK) $(LFLAGS) -o $(TARGET)  $(OBJECTS) $(OBJCOMP) $(LIBS)
	/usr/libexec/PlistBuddy -c "Add :NSMicrophoneUsageDescription string 'This app needs access to your microphone to make SIP voice calls and test VoIP connectivity.'" SIPConnectivityTester.app/Contents/Info.plist 2>/dev/null || true; /usr/libexec/PlistBuddy -c "Add :NSCameraUsageDescription string 'This app needs access to your camera for video calls.'" SIPConnectivityTester.app/Contents/Info.plist 2>/dev/null || true;

